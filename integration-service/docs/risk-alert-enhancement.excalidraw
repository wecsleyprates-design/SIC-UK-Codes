      "fontFamily": 5,
      "text": "\n- Add columns integration_task_id & score_trigger_id\n- Update integration_task_id & score_trigger_id\n- Add NOT NULL constraint on the combination of integration_task_id\nand score_trigger_id\nALTER TABLE your_table_name\nADD CONSTRAINT at_least_one_not_null \nCHECK (integration_task_id IS NOT NULL OR score_trigger_id IS NOT NULL);\n- delete column cause_id\n\n\nMake sure you are replacing cause_id in create_risk_alert with integration_task_id \nor score_trigger_id",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
