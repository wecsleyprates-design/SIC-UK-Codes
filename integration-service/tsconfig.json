{
	"compilerOptions": {
		"target": "ESNext",
		"module": "CommonJS",
		"rootDir": ".",
		"types": ["node", "jest"],
		"baseUrl": ".",
		"allowJs": true,
		"checkJs": false,
		"declaration": true,
		"declarationMap": false,
		"emitDeclarationOnly": false,
		"sourceMap": true,
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"noImplicitAny": false,
		"strictNullChecks": true,
		"strictFunctionTypes": true,
		"strictBindCallApply": true,
		"skipLibCheck": true,
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,
		"outDir": "./dist",
		"paths": {
			"#api": ["./src/api"],
			"#api/*": ["./src/api/*"],
			"#common": ["./src/common/"],
			"#common/*": ["./src/common/*"],
			"#clients": ["./src/clients/"],
			"#clients/*": ["./src/clients/*"],
			"#configs": ["./src/configs"],
			"#configs/*": ["./src/configs/*"],
			"#core": ["./src/core/"],
			"#core/*": ["./src/core/*"],
			"#constants": ["./src/constants"],
			"#constants/*": ["./src/constants/*"],
			"#decorators": ["./src/decorators/"],
			"#decorators/*": ["./src/decorators/*"],
			"#helpers": ["./src/helpers/"],
			"#helpers/*": ["./src/helpers/*"],
			"#lib": ["./lib/"],
			"#lib/*": ["./lib/*"],
			"#messaging": ["./src/messaging/"],
			"#messaging/*": ["./src/messaging/*"],
			"#middlewares": ["./src/middlewares/"],
			"#middlewares/*": ["./src/middlewares/*"],
			"#models": ["./src/models/"],
			"#models/*": ["./src/models/*"],
			"#types": ["./src/types/"],
			"#types/*": ["./src/types/*"],
			"#utils": ["./src/utils/"],
			"#utils/*": ["./src/utils/*"],
			"#workers/": ["./src/workers/"],
			"#workers/*": ["./src/workers/*"],
			"@api/trulioo": ["./lib/trulioo"]
		}
	},
	"include": ["src/**/*.ts", "src/**/*.js", "lib/**/*.ts", "lib/**/*.js"],
	"exclude": ["node_modules", "<node_internals>/**", "dist", "__mocks__"]
}
