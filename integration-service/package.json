{
	"name": "integration-service",
	"version": "1.0.0",
	"description": "Boilerplate for Worth-AI",
	"private": true,
	"author": "Worth-AI",
	"license": "MIT",
	"scripts": {
		"start": "npm run build:clean && cross-env-shell NODE_ENV=production npx babel-node dist/src/index.js | cross-env-shell NODE_ENV=production rotate-logs --config=$INIT_CWD/dist/src/configs/app-log.config.js | cross-env-shell NODE_ENV=production rotate-logs --config=$INIT_CWD/dist/src/configs/http-request-log.config.js",
		"start:prod": "npm run build:clean && cross-env-shell NODE_ENV=production npx babel-node dist/src/index.js",
		"start:dev": "cross-env-shell NODE_ENV=development node --inspect=0.0.0.0:9229 -r ts-node/register -r tsconfig-paths/register src/index.ts",
		"start:debug": "cross-env-shell NODE_ENV=development node --inspect -r ts-node/register -r tsconfig-paths/register src/index.ts",
		"dev": "nodemon --legacy-watch --watch src --watch lib --ext js,ts,json --exec \"npm run start:dev\"",
		"devdebug": "nodemon --watch src --watch lib --ext js,ts,json --exec \"npm run start:debug\"",
		"dev:babel": "npm run build:clean && cross-env-shell NODE_ENV=development npx babel-node dist/src/index.js",
		"debug": "cross-env-shell NODE_ENV=development ts-node -r tsconfig-paths/register  ./src/index.ts",
		"test": "jest --colors --verbose --detectOpenHandles",
		"test:watch": "jest --watchAll",
		"test:coverage": "jest --coverage --coverageReporters=text-summary --coverageReporters=lcov --passWithNoTests",
		"test:coverage-ci": "jest --coverage --reporters=jest-junit | tee ./coverage.txt",
		"prepare": "husky install",
		"commit": "cz",
		"lint": "eslint . --ext .js",
		"lint:fix": "npm run lint -- --fix",
		"format": "prettier --check \"**/*.+(js|ts|json)\"",
		"format:fix": "prettier --write \"**/*.+(js|ts|json)\"",
		"db": "cross-env-shell db-migrate -m '$INIT_CWD/db/migrations'",
		"db:create": "npm run db db:create",
		"db:drop": "npm run db db:drop",
		"migrate:up": "npm run db up:migrate",
		"migrate:down": "npm run db down:migrate",
		"migrate:create": "npm run db create:migrate",
		"migrate:reset": "npm run db reset:migrate",
		"seed:up": "npm run db up:seed",
		"seed:down": "npm run db down:seed",
		"seed:create": "npm run db create:seed",
		"build": "tsc",
		"build:clean": "tsc --build --clean && npm run build",
		"run-cron": "npm run build:clean && cross-env NODE_ENV=production npx babel-node dist/src/cron/run-cron.js",
		"module:create": "cross-env NODE_OPTIONS=\"--import tsx\" plop --plopfile=plopfile.ts",
		"start-job-worker": "npx babel-node dist/src/workers/jobWorker.js"
	},
