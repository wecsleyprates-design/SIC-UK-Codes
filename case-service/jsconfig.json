{
	"compilerOptions": {
		"baseUrl": ".",
		"module": "esnext",
		"allowUnusedLabels": false,
		"moduleResolution": "node",
		"paths": {
			"#configs/*": ["./src/configs/*"],
			"#constants/*": ["./src/constants/*"],
			"#helpers/*": ["./src/helpers/*"],
			"#middlewares/*": ["./src/middlewares/*"],
			"#utils/*": ["./src/utils/*"],
			"#lib/*": ["./lib/*"],
			"#types/*": ["./src/types/*"],
			"#common/*": ["./src/common/*"]
		}
	},
	"exclude": ["node_modules"]
}
