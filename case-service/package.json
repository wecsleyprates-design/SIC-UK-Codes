{
	"name": "case-service",
	"version": "1.0.0",
	"description": "Boilerplate for Worth-AI",
	"private": true,
	"author": "Worth-AI",
	"license": "MIT",
	"engines": {
		"node": "24.x",
		"npm": ">=11"
	},
	"scripts": {
		"start": "npm run build:clean && cross-env NODE_ENV=production npx babel-node dist/src/index.js",
		"start:prod": "npm run build:clean && cross-env NODE_ENV=production npx babel-node dist/src/index.js",
		"start:dev": "cross-env NODE_ENV=development node --inspect=0.0.0.0:9229 --enable-source-maps -r tsconfig-paths/register -r ts-node/register src/index.ts",
		"dev:babel": "npm run build:clean && cross-env NODE_ENV=development npx babel-node dist/src/index.js",
		"dev": "nodemon --watch src --watch lib --ext js,ts,json --exec \"npm run start:dev\"",
		"debug": "cross-env NODE_ENV=development node --inspect --enable-source-maps -r tsconfig-paths/register -r ts-node/register src/index.ts",
		"test": "cross-env TZ=UTC NODE_ENV=test jest -i --colors --verbose --detectOpenHandles",
		"test:watch": "cross-env NODE_ENV=test jest -i --watchAll",
		"test:coverage": "cross-env NODE_ENV=test jest -i --coverage --coverageReporters=text-summary --coverageReporters=lcov --passWithNoTests",
		"test:coverage-ci": "jest --coverage --reporters=jest-junit | tee ./coverage.txt",
		"prepare": "husky",
		"commit": "cz",
		"lint": "eslint . --ext .js --ext .ts",
		"lint:fix": "npm run lint -- --fix",
		"format": "prettier --check **/*.js",
		"format:fix": "prettier --write **/*.js",
		"db": "cross-env-shell db-migrate -m '$INIT_CWD/db/migrations'",
		"db:create": "npm run db db:create",
		"db:drop": "npm run db db:drop",
		"migrate:up": "npm run db up:migrate",
		"migrate:down": "npm run db down:migrate",
		"migrate:create": "npm run db create:migrate",
		"migrate:reset": "npm run db reset:migrate",
		"seed:up": "npm run db up:seed",
		"seed:down": "npm run db down:seed",
		"seed:create": "npm run db create:seed",
		"build": "tsc",
		"build:clean": "tsc --build --clean && npm run build",
		"run-cron": "npm run build:clean && cross-env NODE_ENV=production npx babel-node dist/src/cron/run-cron.js",
		"module:create": "cross-env NODE_OPTIONS=\"--import tsx\" plop --plopfile=plopfile.ts",
		"route:create": "cross-env NODE_OPTIONS=\"--import tsx\" plop route --plopfile=plopfile.ts"
	},
