NODE_ENV=development
SUBDOMAIN=your-subdomain

CONFIG_APP_PORT=3003
# CONFIG_SERVICE_MODE=api | worker (omit to run both - legacy/local)
# CONFIG_SERVICE_MODE=api
# CONFIG_SERVICE_MODE=worker
CONFIG_SERVICE_MODE=

CONFIG_APPLICANT_CLIENT_ID=applicant-client-id
CONFIG_APPLICANT_FRONTEND_BASE_URL=https://applicant.example.com
CONFIG_APPLICANT_USER_POOL_ID=applicant-user-pool-id

CONFIG_AUTH_BASE_URL=http://auth-services:80
CONFIG_WAREHOUSE_BASE_URL=http://warehouse-services:80

CONFIG_AWS_ACCESS_KEY_ID=aws-access-key-id
CONFIG_AWS_ACCESS_KEY_SECRET=aws-secret-access-key

CONFIG_AWS_BACKEND_BUCKET=backend-bucket-name (not in old file)
CONFIG_AWS_COGNITO_REGION=us-east-1

CONFIG_AWS_DATA_ACCESS_KEY_ID=data-access-key-id
CONFIG_AWS_DATA_ACCESS_KEY_SECRET=data-access-secret

CONFIG_AWS_ELECTRONIC_CONSENT_BUCKET=econsent-bucket-name

CONFIG_AWS_SES_REGION=us-east-1

CONFIG_CRYPTO_IV=crypto-iv-value
CONFIG_CRYPTO_SECRET_KEY=crypto-secret-key

CONFIG_CUSTOM_FIELDS_TEMPLATE=custom-fields-template-id

CONFIG_CUSTOMER_ADMIN_FRONTEND_BASE_URL=https://customer.example.com

CONFIG_CUSTOMER_CLIENT_ID=customer-client-id
CONFIG_CUSTOMER_USER_POOL_ID=customer-user-pool-id

CONFIG_DB_HOST=localhost
CONFIG_DB_MAX_CONNECTIONS=20
CONFIG_DB_NAME=your-database-name
CONFIG_DB_PASSWORD=your-db-password
CONFIG_DB_PORT=5432
CONFIG_DB_USER=your-db-user

CONFIG_ECONSENT_API_KEY=econsent-api-key

CONFIG_EIN_ENCRYPTION_CRYPTO_IV=crypto-iv-v2-value
CONFIG_EIN_ENCRYPTION_CRYPTO_SECRET_KEY=crypto-secret-key-v2

CONFIG_ELECTRONIC_CONSENT_BASE_URL=https://api.example.com/econsent

CONFIG_EMAIL_USER=your-email@example.com

CONFIG_ENTERPRISE_APPLICANT_ID=enterprise-applicant-id

CONFIG_FRONTEND_LOCAL_BASE_URLS=https://localhost:5173,https://localhost:5174,https://localhost:5175

CONFIG_INTEGRATION_BASE_URL=https://api.example.com/integrations

CONFIG_JWT_REFRESH_SECRET_KEY=refresh-secret-key
CONFIG_JWT_SECRET_KEY=jwt-secret-key

CONFIG_KAFKA_BROKERS=localhost:9092
CONFIG_KAFKA_CLIENT_ID=kafka-client-id
CONFIG_KAFKA_GROUP_ID=kafka-group-id

CONFIG_KAFKA_SASL_PASSWORD=kafka-sasl-password
CONFIG_KAFKA_SASL_USERNAME=kafka-sasl-username

CONFIG_KAFKA_SSL_ENABLED=false

CONFIG_LD_INTIALIZATION_TIMEOUT=10
CONFIG_LD_SDK_KEY=launchdarkly-sdk-key

CONFIG_LOG_LEVEL=debug

CONFIG_MANUAL_SCORE_BASE_URL=http://manual-score-services:80

CONFIG_REDIS_DISABLE_TLS_REJECT_UNAUTHORIZED=false
CONFIG_REDIS_DISABLE_TLS=false

CONFIG_REDIS_EC_CLUSTER=cluster-id
CONFIG_REDIS_HOST=localhost
CONFIG_REDIS_PASSWORD=redis-password
CONFIG_REDIS_PORT=6379
CONFIG_REDIS_RECONNECT_MAX_WAIT=2000
CONFIG_REDIS_URL=redis://localhost:6379
CONFIG_REDIS_KEY_PREFIX=""

CONFIG_REPORT_BASE_URL=https://reports.example.com

CONFIG_STRIPE_SECRET_KEY=stripe-secret-key

CONFIG_STRIPE_SUBSCRIPTION_CANCEL_URL=https://example.com/stripe/cancel
CONFIG_STRIPE_SUBSCRIPTION_SUCCESS_URL=https://example.com/stripe/success
CONFIG_STRIPE_SUBSCRIPTIONS_WEBHOOK_SECRET=webhook-secret

CONFIG_TIN_VERIFICATION_ATTEMPTS=3

CONFIG_WORTH_ADMIN_CLIENT_ID=worth-admin-client-id
CONFIG_WORTH_ADMIN_FRONTEND_BASE_URL=https://admin.example.com
CONFIG_WORTH_ADMIN_USER_POOL_ID=worth-user-pool-id

STRIPE_API_KEY=stripe-api-key

CONFIG_BUSINESS=business.v1
CONFIG_CASES=cases.v1
CONFIG_DLQTOPIC=dlq-topic
CONFIG_EMAIL_HOST=email.example.com
CONFIG_EMAIL_PASSWORD=email-password
CONFIG_EMAIL_PORT=587
CONFIG_FRONTEND_BASE_URL=https://frontend.example.com
CONFIG_INTEGRATIONS=integrations.v1
CONFIG_LD_TEST_FLAGS_FILE=ld-test-flags.json
CONFIG_NOTIFICATIONS=notifications.v1
CONFIG_REPORTS=reports.v1
CONFIG_SCORES=scores.v1
CONFIG_USERS_NEW=users.v1
CONFIG_WEBHOOKS=webhooks.v1

DD_ENV="test"
DD_SERVICE="case-service"
# Health check mode: When true, the app verifies connectivity to all dependencies
# (DB, Kafka, Redis) without actually consuming Kafka messages or processing Bull
# queue jobs. Used in CI/CD pipelines for pre-deployment verification.
CONFIG_HEALTH_CHECK_MODE=false
