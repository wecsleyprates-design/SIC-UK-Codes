NODE_ENV=development
CONFIG_APP_PORT=3000
SUBDOMAIN=subdomain-here

CONFIG_DB_HOST=localhost
CONFIG_DB_PORT=5432
CONFIG_DB_USER=db-username
CONFIG_DB_PASSWORD=db-password
CONFIG_DB_NAME=db-name
CONFIG_DB_MAX_CONNECTIONS=db-max-connections

CONFIG_JWT_SECRET_KEY=secret-key-here
CONFIG_JWT_REFRESH_SECRET_KEY=refresh-secret-key-here

CONFIG_EMAIL_HOST=email-server
