{
	"name": "score-service",
	"version": "1.0.0",
	"description": "Boilerplate for Worth-AI",
	"private": true,
	"author": "Worth-AI",
	"license": "MIT",
	"scripts": {
		"start": "npm run build:clean && cross-env-shell NODE_ENV=production node --heap-snapshot-on-oom --heapsnapshot-signal=SIGUSR2 ./node_modules/@babel/node/bin/babel-node.js dist/src/index.js | cross-env-shell NODE_ENV=production rotate-logs --config=$INIT_CWD/dist/src/configs/app-log.config.js | cross-env-shell NODE_ENV=production rotate-logs --config=$INIT_CWD/dist/src/configs/http-request-log.config.js",
		"start:prod": "npm run build:clean && cross-env-shell NODE_ENV=production node --heap-snapshot-on-oom --heapsnapshot-signal=SIGUSR2 ./node_modules/@babel/node/bin/babel-node.js dist/src/index.js",
		"start:dev": "cross-env-shell NODE_ENV=development node --inspect=0.0.0.0:9229 --heapsnapshot-signal=SIGUSR2 -r ts-node/register -r tsconfig-paths/register src/index.ts",
		"dev": "nodemon --legacy-watch --watch src --watch lib --ext js,ts,json --exec \"npm run start:dev\"",
		"dev:babel": "npm run build:clean && cross-env-shell NODE_ENV=development npx babel-node dist/src/index.js",
		"debug": "cross-env-shell NODE_ENV=development ts-node -r tsconfig-paths/register  ./src/index.ts",
		"test": "jest -i --colors --verbose --detectOpenHandles",
		"test:watch": "jest -i --watchAll",
		"test:coverage": "jest -i --coverage --coverageReporters=text-summary --coverageReporters=lcov --passWithNoTests",
		"test:coverage-ci": "jest --coverage --reporters=jest-junit | tee ./coverage.txt",
		"prepare": "husky install",
		"commit": "cz",
		"lint": "eslint . --ext .js",
		"lint:fix": "npm run lint -- --fix",
		"format": "prettier --check \"**/*.+(js|ts|json)\"",
		"format:fix": "prettier --write \"**/*.+(js|ts|json)\"",
		"db": "cross-env-shell db-migrate -m '$INIT_CWD/db/migrations'",
		"db:create": "npm run db db:create",
		"db:drop": "npm run db db:drop",
		"migrate:up": "npm run db up:migrate",
		"migrate:down": "npm run db down:migrate",
		"migrate:create": "npm run db create:migrate",
		"migrate:reset": "npm run db reset:migrate",
		"seed:up": "npm run db up:seed",
		"seed:down": "npm run db down:seed",
		"seed:create": "npm run db create:seed",
		"build": "tsc",
		"build:clean": "tsc --build --clean && npm run build",
		"module:create": "cross-env NODE_OPTIONS=\"--import tsx\" plop --plopfile=plopfile.ts",
		"heap-snapshot": "bash scripts/heap-snapshot.sh"
	},
	"dependencies": {
		"@babel/core": "7.28.3",
		"@babel/node": "^7.22.19",
		"@babel/preset-env": "7.28.3",
		"@babel/register": "^7.22.15",
		"@joinworth/types": "^0.0.11",
		"@joinworth/worth-core-service": "^1.1.0",
		"@joinworth/worth-core-utils": "^0.2.0",
		"@launchdarkly/node-server-sdk": "^9.5.0",
		"@vrbo/pino-rotating-file": "^4.4.0",
		"aws-jwt-verify": "^4.0.0",
		"axios": "^1.12.0",
		"bcryptjs": "^2.4.3",
		"bull": "^4.16.5",
		"cookie-parser": "^1.4.6",
		"cors": "^2.8.5",
		"crypto-js": "^4.1.1",
		"db-migrate": "^0.11.14",
		"db-migrate-pg": "^1.5.2",
		"dotenv": "^16.3.1",
		"express": "^4.21.2",
		"express-useragent": "^1.0.15",
		"google-libphonenumber": "^3.2.33",
		"handlebars": "^4.7.8",
		"helmet": "^7.0.0",
		"http-errors": "~2.0.0",
		"http-status-codes": "^2.3.0",
		"ioredis": "^5.6.1",
		"joi": "^17.13.1",
		"joi-password-complexity": "^5.2.0",
		"joi-phone-number": "^5.1.1",
		"jsonwebtoken": "^9.0.2",
		"kafkajs": "^2.2.4",
		"multer": "2.0.2",
		"nodemailer": "^6.9.9",
		"pg": "^8.11.3",
		"pino": "^9.13.1",
		"pino-http": "^10.5.0",
		"randomatic": "^3.1.1",
		"semver": "^7.5.4",
		"swagger-ui-express": "^5.0.0",
		"timekeeper": "^2.3.1",
		"uuid": "^9.0.1",
		"zod": "^3.25.3"
	},
	"devDependencies": {
		"@babel/cli": "^7.23.4",
		"@babel/core": "7.28.3",
		"@babel/preset-env": "7.28.3",
		"@babel/preset-typescript": "^7.23.3",
		"@commitlint/cli": "^17.7.2",
		"@commitlint/config-conventional": "^17.7.0",
		"@types/babel__core": "~7.20.5",
		"@types/babel__preset-env": "~7.9.6",
		"@types/babel__register": "~7.17.3",
		"@types/bcryptjs": "~2.4.6",
		"@types/cookie-parser": "~1.4.6",
		"@types/cors": "~2.8.17",
		"@types/crypto-js": "~4.1.3",
		"@types/db-migrate-pg": "~0.0.13",
		"@types/eslint": "~8.56.1",
		"@types/eslint-config-prettier": "~6.11.3",
		"@types/express": "^4.17.21",
		"@types/express-useragent": "~1.0.5",
		"@types/google-libphonenumber": "~7.4.30",
		"@types/http-errors": "~2.0.4",
		"@types/http-status-codes": "~1.2.0",
		"@types/jest": "^29.5.12",
		"@types/joi-phone-number": "~5.0.8",
		"@types/jsend": "^1.0.32",
		"@types/jsonwebtoken": "~9.0.5",
		"@types/lint-staged": "~13.3.0",
		"@types/localtunnel": "~2.0.4",
		"@types/multer": "^1.4.12",
		"@types/node": "^20.10.6",
		"@types/nodemailer": "~6.4.14",
		"@types/nodemon": "~1.19.6",
		"@types/pg": "~8.10.9",
		"@types/randomatic": "~3.1.5",
		"@types/semver": "~7.5.6",
		"@types/swagger-ui-express": "~4.1.6",
		"@types/uuid": "~9.0.7",
		"@typescript-eslint/eslint-plugin": "^6.17.0",
		"@typescript-eslint/parser": "^6.17.0",
		"babel-jest": "^29.7.0",
		"babel-plugin-module-resolver": "^5.0.0",
		"commitizen": "^4.3.0",
		"cross-env": "^7.0.3",
		"cz-conventional-changelog": "^3.3.0",
		"eslint": "^8.56.0",
		"eslint-config-prettier": "^9.0.0",
		"eslint-config-standard-with-typescript": "^43.0.1",
		"eslint-config-vipul-base": "^1.2.1",
		"eslint-plugin-prettier": "^5.0.1",
		"husky": "^8.0.3",
		"jest": "^29.7.0",
		"lint-staged": "^15.2.10",
		"localtunnel": "^2.0.2",
		"nodemon": "^3.0.1",
		"pino-pretty": "^10.2.3",
		"plop": "^4.0.1",
		"prettier": "^3.0.3",
		"ts-jest": "^29.2.4",
		"tsconfig-paths": "^4.2.0",
		"tsx": "^4.19.3",
		"typescript": "^5.3.3",
		"typesync": "^0.12.0"
	},
	"nodemonConfig": {
		"ignore": [
			"**/__tests__/**",
			"**/*.test.js"
		],
		"delay": 2500
	},
	"overrides": {
		"axios": "^1.12.0",
		"tmp": "^0.2.5"
	}
}
